// 55. Максимум в начало, минимум в конец
#include <iostream>
using namespace std;
int main(){
    int n; cin>>n; int* a=new int[n];
    for(int i=0;i<n;i++) cin>>a[i];
    int imax=0, imin=0;
    for(int i=1;i<n;i++){ if(a[i]>a[imax]) imax=i; if(a[i]<a[imin]) imin=i; }
    swap(a[0], a[imax]);
    // если минимум был на 0, после swap его индекс изменился
    if(imin==0) imin=imax;
    swap(a[n-1], a[imin]);
    for(int i=0;i<n;i++) cout<<a[i]<<" ";
    delete[] a;
}

