    if(pos2==-1 || pos1==-1){ cout<<"нет двух положительных"; return 0; }
    long long p=1;
    for(int i=pos2+1;i<pos1;i++) p*=a[i];
    cout<<p;
    delete[] a;
}

// 60. Переставить в обратном порядке между первым положительным и последним отрицательным
#include <iostream>
#include <algorithm>
using namespace std;
int main(){
    int n; cin>>n; int* a=new int[n];
    for(int i=0;i<n;i++) cin>>a[i];
    int firstPos=-1, lastNeg=-1;
    for(int i=0;i<n;i++) if(a[i]>0){ firstPos=i; break; }
    for(int i=n-1;i>=0;i--) if(a[i]<0){ lastNeg=i; break; }
    if(firstPos!=-1 && lastNeg!=-1 && firstPos<lastNeg)
        reverse(a+firstPos, a+lastNeg+1);
    for(int i=0;i<n;i++) cout<<a[i]<<" ";
    delete[] a;
}

