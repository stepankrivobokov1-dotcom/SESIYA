    for(int i=0;i<n;i++) cin>>a[i];
    int pos1=-1, pos2=-1; // последний и предпоследний индексы положительных
    for(int i=n-1;i>=0;i--){
        if(a[i]>0){ if(pos1==-1) pos1=i; else if(pos2==-1){ pos2=i; break; } }
